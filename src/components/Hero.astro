---
---

<div class="hero">
    <div class="hero-logo">
        <img src="/logo-with-text.png" alt="4PP Studio">
    </div>
    <h1><span class="gradient">Fikirleri</span><br>Ürüne Dönüştürüyoruz</h1>
    <p>Bir grup yazılımcı olarak gördüğümüz boşlukları doldurmak için bir araya geldik. Herkesin baktığı yere bakmak yerine kimsenin girmediği kapıları çalmayı tercih ediyoruz.</p>
    <div class="apple-cta">
        <button class="apple-btn" id="products-btn">Ürünler</button>
        <button class="apple-btn secondary">İletişime Geç</button>
    </div>
    
    <div class="scroll-indicator">
        <span>Aşağı Kaydır</span>
        <span class="arrow">↓</span>
    </div>
</div>

<style>
    .hero {
        padding: 100px 20px 120px;
        text-align: center;
        max-width: 980px;
        margin: 0 auto;
        position: relative;
    }

    .hero-logo {
        margin-bottom: 40px;
        opacity: 0;
        transform: translateY(30px);
        animation: fadeUp 1s ease forwards;
    }

    .hero-logo img {
        max-width: 320px;
        height: auto;
    }

    .hero h1 {
        font-size: clamp(48px, 7vw, 80px);
        font-weight: 600;
        line-height: 1.05;
        letter-spacing: -0.015em;
        margin-bottom: 24px;
        opacity: 0;
        transform: translateY(30px);
        animation: fadeUp 1s ease 0.2s forwards;
    }

    .hero h1 .gradient {
        /* background: #1d1d1f; */
        background: linear-gradient(-13deg, #0071e3 0%, #5FECFF 10%, #FFB951 20%, #F90068 30%, #0071e3 40%, #5FECFF 50%, #FFB951 60%, #F90068 70%, #0071e3 80%, #5FECFF 90%, #FFB951 100%);
        background-size: 300% auto;
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gradientFlow 4s ease-in-out forwards;
    }

    @keyframes gradientFlow {
        0% {
            background-position: 0% center;
        }
        50% {
            background-position: 100% center;
        }
        100% {
            background-position: 90% center;
        }
    }

    @keyframes fadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .hero p {
        font-size: clamp(12px, 1vw, 20px);
        font-weight: 400;
        line-height: 1.3;
        color: #6e6e73;
        max-width: 700px;
        margin: 0 auto 60px;
        opacity: 0;
        transform: translateY(30px);
        animation: fadeUp 1s ease 0.4s forwards;
    }

    .apple-cta {
        display: inline-flex;
        gap: 20px;
        opacity: 0;
        transform: translateY(30px);
        animation: fadeUp 1s ease 0.6s forwards;
    }

    .apple-btn {
        background: #0071e3;
        color: #fff;
        border: none;
        padding: 14px 30px;
        border-radius: 980px;
        font-size: 17px;
        font-weight: 400;
        cursor: pointer;
        transition: all 0.3s ease;
        min-width: 140px;
    }

    .apple-btn:hover {
        background: #0077ed;
    }

    .apple-btn.secondary {
        background: transparent;
        color: #0071e3;
    }

    .apple-btn.secondary:hover {
        text-decoration: underline;
    }

    .scroll-indicator {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        animation: bounce 2s infinite;
    }

    .scroll-indicator span {
        font-size: 12px;
        font-weight: 500;
        color: #6e6e73;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .scroll-indicator .arrow {
        font-size: 20px;
    }

    @keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50% { transform: translateX(-50%) translateY(10px); }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 100px 20px 72px;
        }

        .hero-logo img {
            max-width: 160px;
        }

        .hero p {
            font-size: 15px;
            line-height: 1.5;
            margin-bottom: 36px;
            max-width: 100%;
        }

        .apple-cta {
            flex-direction: column;
            width: 100%;
            gap: 12px;
        }

        .apple-btn {
            width: 100%;
            font-size: 16px;
            padding: 12px 20px;
        }

        .scroll-indicator {
            display: none;
        }
    }

    @media (max-width: 480px) {
        .hero {
            padding: 88px 16px 64px;
        }

        .hero h1 {
            font-size: clamp(34px, 11vw, 44px);
            margin-bottom: 16px;
        }

        .hero-logo {
            margin-bottom: 28px;
        }

        .hero-logo img {
            max-width: 130px;
        }
    }
</style>

<script>
    const productsButton = document.querySelector('#products-btn');
    const contactButton = document.querySelector('.apple-btn.secondary');

    if (productsButton) {
        productsButton.addEventListener('click', () => {
            const productsSection = document.querySelector('#products');
            if (productsSection) {
                productsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    }

    if (contactButton) {
        contactButton.addEventListener('click', () => {
            alert('İletişim için: 4ppstudioss@gmail.com');
        });
    }
