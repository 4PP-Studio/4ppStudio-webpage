---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0;url=${href}`} />
    <link rel="canonical" href={href} />
    <title>Yönlendiriliyor…</title>
    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #f8f8fa;
        margin: 0;
        font-family: system-ui, sans-serif;
      }
      .redirect-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
        padding: 24px;
      }
      .spinner {
        width: 48px;
        height: 48px;
        border: 6px solid #cfd0d1;
        border-top: 6px solid #2984f6;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 8px;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .redirect-text {
        font-size: 1.2rem;
        color: #2d2d2f;
        text-align: center;
        max-width: 100%;
      }
      .redirect-text a {
        color: #0071e3;
        text-decoration: underline;
        word-break: break-all;
      }
    </style>
  </head>
  <body>
    <div class="redirect-container">
      <div class="spinner" role="status" aria-label="Yükleniyor"></div>
      <p class="redirect-text">
        Yönlendiriliyor… <a href={href}>{href}</a>
      </p>
    </div>
  </body>
</html>
