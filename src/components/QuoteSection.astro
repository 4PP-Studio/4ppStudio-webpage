<div class="quote-section">
    <div class="quote-bg"></div>
    <blockquote>En değerli fırsatlar, keşfedilmemiş alanlarda saklı.</blockquote>
    <cite>— 4PP Studio Ekibi</cite>
</div>

<style>
    .quote-section {
        padding: 160px 20px 120px 20px;
        text-align: center;
        max-width: 900px;
        margin: 0 auto;
        position: relative;
    }

    .quote-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        corner-shape: squircle;
        background: url('/bg-2.svg') center/cover no-repeat;
        opacity: 0.5;
        z-index: -1;
        pointer-events: none;
        border-radius: 100px;
    }

    .quote-section blockquote {
        font-size: clamp(28px, 5vw, 38px);
        font-weight: 500;
        line-height: 1.3;
        color: #1d1d1f;
        margin-bottom: 40px;
        letter-spacing: -0.02em;
        position: relative;
        z-index: 1;
    }

    .quote-section cite {
        font-size: 1.1rem;
        color: #6e6e73;
        font-style: normal;
        font-weight: 400;
        position: relative;
        z-index: 1;
    }

    @media (max-width: 768px) {
        .quote-section blockquote {
            font-size: 1.8rem;
        }
    }
</style>
